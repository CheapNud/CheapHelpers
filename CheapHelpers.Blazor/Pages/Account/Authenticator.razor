@using CheapHelpers.Blazor.Helpers
@using CheapHelpers.Blazor.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@attribute [Authorize]

<MudText>@Loc["AuthenticatorInstructions"]</MudText>
<MudList T="string">
    <MudListItem>
        <MudText>
            @Loc["DownloadAuthenticatorApp"]
            <MudLink Href="https://go.microsoft.com/fwlink/?Linkid=825072">Android</MudLink> /
            <MudLink Href="https://go.microsoft.com/fwlink/?Linkid=825073">iOS</MudLink>
            (Microsoft Authenticator)
            @Loc["Or"]
            <MudLink Href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&amp;hl=en">Android</MudLink> /
            <MudLink Href="https://itunes.apple.com/us/app/google-authenticator/id388497605?mt=8">iOS</MudLink>
            (Google Authenticator).
        </MudText>
    </MudListItem>

    <MudListItem>
        <MudText>@Loc["ScanQROrEnterKey"] <kbd>@SharedKey</kbd></MudText>
        <div id="qrCode"></div>
        <div id="qrCodeData" data-url="@AuthenticatorUri"></div>
    </MudListItem>

    <MudListItem>
        <MudText>@Loc["EnterVerificationCode"]</MudText>
    </MudListItem>
</MudList>

<form @ref="_form" class="mt-3" method="post" action="/Account/EnableAuthenticator">
    <MudTextField Variant="Variant.Outlined" Label="@Loc["VerificationCode"]"
                  @bind-Value="VerificationCode" @onkeypress="HandleKeyPress" />
    <MudButton Class="mt-3" Variant="Variant.Filled" FullWidth="true"
               Color="Color.Primary" ButtonType="ButtonType.Submit">
        @Loc["Verify"]
    </MudButton>
</form>

@code {
    [Parameter] public string AppName { get; set; } = "CheapHelpers";

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    [Inject] protected UserManager<CheapUser> UserManager { get; set; } = default!;
    [Inject] protected UserService UserService { get; set; } = default!;
    [Inject] protected IJSRuntime Js { get; set; } = default!;
    [Inject] protected ISnackbar ToastService { get; set; } = default!;
    [Inject] protected IStringLocalizer Loc { get; set; } = default!;

    private CheapUser? User;
    private string SharedKey = "";
    private string AuthenticatorUri = "";
    private string VerificationCode = "";
    private object? _form;

    protected override async Task OnInitializedAsync()
    {
        User = await UserService.GetUserAsync(AuthenticationStateTask);
        if (User is null) return;

        try
        {
            var unformattedKey = await UserManager.GetAuthenticatorKeyAsync(User);
            if (string.IsNullOrEmpty(unformattedKey))
            {
                await UserManager.ResetAuthenticatorKeyAsync(User);
                unformattedKey = await UserManager.GetAuthenticatorKeyAsync(User);
            }

            SharedKey = AuthenticatorHelper.FormatKey(unformattedKey!);
            var email = await UserManager.GetEmailAsync(User);
            AuthenticatorUri = AuthenticatorHelper.GenerateQrCodeUri(AppName, email!, unformattedKey!);
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"Failed to load authenticator key: {ex.Message}");
            ToastService.Add(Loc["ErrorMessage"], Severity.Error);
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs args)
    {
        if (args.Code is "Enter" or "NumpadEnter")
        {
            await Js.InvokeVoidAsync("submitForm", _form);
        }
    }
}
