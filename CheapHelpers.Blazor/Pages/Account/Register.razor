@page "/Account/Register"
@using CheapHelpers.Blazor.Shared
@using CheapHelpers.Services.Email
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using System.Text

<MudForm @ref="_form" Model="@_model" Validation="@(_validator?.ValidateValue)">
    <MudTextField Class="mt-3" Label="@Loc["FirstName"]" Variant="Variant.Outlined"
                  @bind-Value="_model.FirstName" For="@(() => _model.FirstName)" />
    <MudTextField Class="mt-3" Label="@Loc["LastName"]" Variant="Variant.Outlined"
                  @bind-Value="_model.LastName" For="@(() => _model.LastName)" />
    <MudTextField Class="mt-3" Label="@Loc["Email"]" Required="true" InputMode="InputMode.email"
                  InputType="InputType.Email" Variant="Variant.Outlined"
                  @bind-Value="_model.Email" For="@(() => _model.Email)" />
    <PasswordTextField For="@(() => _model.Password)" Class="mt-3" @bind-Value="_model.Password" />
    <PasswordTextField For="@(() => _model.ConfirmPassword)" Class="mt-3" @bind-Value="_model.ConfirmPassword" />
</MudForm>
<MudCheckBox @bind-Value="_sendMail" Label="@Loc["SendConfirmationEmail"]" Class="mt-3" Color="Color.Primary" />
<MudButton Class="mt-3" Variant="Variant.Filled" Color="Color.Primary" OnClick="RegisterAccount">
    @Loc["Create"]
</MudButton>

@code {
    public class RegisterViewModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }

    /// <summary>
    /// Factory to create a concrete CheapUser instance.
    /// Required because CheapUser is abstract — consumers must provide their concrete type.
    /// </summary>
    [Parameter, EditorRequired]
    public Func<CheapUser> UserFactory { get; set; } = default!;

    /// <summary>
    /// Optional callback after successful registration.
    /// </summary>
    [Parameter]
    public EventCallback<CheapUser> OnUserRegistered { get; set; }

    [Inject] protected UserManager<CheapUser> UserManager { get; set; } = default!;
    [Inject] protected IEmailService? Mailer { get; set; }
    [Inject] protected ISnackbar ToastService { get; set; } = default!;
    [Inject] protected NavigationManager Nav { get; set; } = default!;
    [Inject] protected IStringLocalizer Loc { get; set; } = default!;
    [Inject] protected IDbContextFactory<CheapContext<CheapUser>> Factory { get; set; } = default!;

    private RegisterViewModel _model = new();
    private MudForm _form = default!;
    private RegisterValidator? _validator;
    private bool _sendMail;

    protected override void OnInitialized()
    {
        _validator = new RegisterValidator();
    }

    private async Task SendConfirmationMail(CheapUser user)
    {
        if (Mailer is null || string.IsNullOrEmpty(user.Email)) return;

        try
        {
            var code = await UserManager.GenerateEmailConfirmationTokenAsync(user);
            code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));
            var link = $"{Nav.BaseUri}Account/ConfirmEmail?userid={user.Id}&code={code}";
            await Mailer.SendEmailConfirmationAsync(user.Email, link);
        }
        catch (Exception ex)
        {
            Debug.WriteLine(ex.Message);
        }
    }

    private async Task RegisterAccount()
    {
        try
        {
            await _form.Validate();
            if (!_form.IsValid)
            {
                ToastService.Add(string.Join("<br>", _form.Errors), Severity.Warning);
                return;
            }

            var user = UserFactory();
            user.FirstName = _model.FirstName;
            user.LastName = _model.LastName;
            user.Email = _model.Email;
            user.UserName = _model.Email;

            var identityResult = await UserManager.CreateAsync(user, _model.Password);
            if (identityResult.Succeeded)
            {
                if (_sendMail)
                {
                    await SendConfirmationMail(user);
                    ToastService.Add(Loc["ConfirmationEmailSent"], Severity.Success);
                }

                if (OnUserRegistered.HasDelegate)
                {
                    await OnUserRegistered.InvokeAsync(user);
                }

                _model = new();
            }
            else
            {
                foreach (var error in identityResult.Errors)
                {
                    ToastService.Add(error.Description, Severity.Warning);
                }
            }
        }
        catch (Exception ex)
        {
            Debug.WriteLine(ex.Message);
            throw;
        }
    }
}
