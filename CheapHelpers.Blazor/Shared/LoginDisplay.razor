@using CheapHelpers.Blazor.Services
@using CheapHelpers.Services.Notifications
@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView>
    <Authorized>
        @if (User != null)
        {
            <MudGrid Justify="Justify.FlexEnd">
                <MudItem>
                    <MudPaper>
                        <CultureSelector />
                    </MudPaper>
                </MudItem>
                <MudItem>
                    <MudMenu Class="mr-1">
                        <ActivatorContent Context="activatorcontext">
                            @if (UnreadCount > 0)
                            {
                                <MudBadge Content="@UnreadCount" Color="Color.Success" Overlap="true" Bordered="true">
                                    <MudAvatar Size="Size.Medium" Color="Color.Info">@User.Initials</MudAvatar>
                                </MudBadge>
                            }
                            else
                            {
                                <MudAvatar Size="Size.Medium" Color="Color.Info">@User.Initials</MudAvatar>
                            }
                        </ActivatorContent>
                        <ChildContent>
                            @if (UnreadCount > 0)
                            {
                                <MudMenuItem Href="Account/Notifications">
                                    @(UnreadCount > 99 ? "99+" : UnreadCount.ToString()) @Loc["Messages"]
                                </MudMenuItem>
                            }
                            <MudMenuItem Href="Account">
                                @Loc["Profile"]
                            </MudMenuItem>
                            <MudDivider />
                            <MudMenuItem>
                                <MudForm method="post" action="/Account/SignOut">
                                    <MudButton ButtonType="ButtonType.Submit" IconSize="Size.Small"
                                               Color="Color.Secondary" Size="Size.Medium" Variant="Variant.Filled">
                                        @Loc["LogOut"]
                                    </MudButton>
                                </MudForm>
                            </MudMenuItem>
                        </ChildContent>
                    </MudMenu>
                </MudItem>
            </MudGrid>
        }
    </Authorized>
    <NotAuthorized>
        <MudLink Color="Color.Tertiary" Href="/Account/Login">@Loc["LogIn"]</MudLink>
    </NotAuthorized>
</AuthorizeView>

@code {
    private CheapUser? User;
    private int UnreadCount;

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationState { get; set; } = default!;

    [Inject] protected UserService UserService { get; set; } = default!;
    [Inject] protected IInAppNotificationService? NotificationService { get; set; }
    [Inject] protected IStringLocalizer Loc { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationState;
        if (auth.User.Identity?.IsAuthenticated == true)
        {
            User = await UserService.GetUserAsync(auth.User);

            if (NotificationService is not null)
            {
                UnreadCount = await NotificationService.GetUnreadCountAsync(User.Id);
            }
        }
    }
}
